# Database
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/music_practice_db"

# JWT
JWT_SECRET="tu-secreto-jwt-muy-seguro-y-largo-minimo-32-caracteres-aqui"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google Cloud Translation (Opcional)
GOOGLE_TRANSLATE_API_KEY=""

# AWS S3 (Opcional - para producción)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="music-practice-pdfs"
